generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  POLICYHOLDER
  CONTRACTOR
  ADMIN
}

enum ContractorTradeType {
  WATER
  ROOF
  STRUCTURAL
}

enum TosStatus {
  SENT
  SIGNED
  VETTED
}

enum BenefitStatus {
  NETWORK_100
  CASH_80
}

enum ClaimStatus {
  REPORTED
  BLASTING
  ASSIGNED
  CHECKED_IN
  INSPECTION_COMPLETE
  CLOSED
}

enum DispatchOutcome {
  PENDING
  ACCEPTED
  EXPIRED
  DECLINED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  policyholderProfile PolicyholderProfile?
  contractorProfile   ContractorProfile?
  reviewedPendingContractors PendingContractor[] @relation("ReviewedByAdmin")
}

model PolicyholderProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  phone          String?
  defaultAddress String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  claims Claim[]
  suggestedContractors PendingContractor[] @relation("SubmittedByPolicyholder")
}

model ContractorProfile {
  id          String             @id @default(cuid())
  userId      String             @unique
  companyName String
  tradeType   ContractorTradeType
  latitude    Decimal            @db.Decimal(10, 7)
  longitude   Decimal            @db.Decimal(10, 7)
  radiusKm    Int                @default(50)
  tosStatus   TosStatus          @default(SENT)
  isVetted    Boolean            @default(false)
  isFlagged   Boolean            @default(false)
  communicationRating    Decimal @default(3.0) @db.Decimal(3, 2)
  professionalismRating  Decimal @default(3.0) @db.Decimal(3, 2)
  punctualityRating      Decimal @default(3.0) @db.Decimal(3, 2)
  cleanlinessRating      Decimal @default(3.0) @db.Decimal(3, 2)
  qualityRating          Decimal @default(3.0) @db.Decimal(3, 2)
  championScore          Decimal @default(3.0) @db.Decimal(3, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedClaims Claim[]      @relation("AssignedContractor")
  dispatchLogs  DispatchLog[]
}

model Claim {
  id               String       @id @default(cuid())
  policyholderId   String
  addressLine1     String
  city             String
  state            String       @default("FL")
  zip              String
  latitude         Decimal      @db.Decimal(10, 7)
  longitude        Decimal      @db.Decimal(10, 7)
  perilType        String
  description      String
  photoUrls        String[]     @default([])
  benefitStatus    BenefitStatus @default(NETWORK_100)
  status           ClaimStatus  @default(REPORTED)
  assignedContractorId String?
  assignedAt           DateTime?
  inspectionCompletedAt DateTime?
  closedAt             DateTime?
  xactimateUnitPriceTotal Decimal? @db.Decimal(12, 2)
  calculatedPayout        Decimal? @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  policyholder       PolicyholderProfile @relation(fields: [policyholderId], references: [id])
  assignedContractor ContractorProfile?  @relation("AssignedContractor", fields: [assignedContractorId], references: [id])
  dispatchLogs       DispatchLog[]
}

model DispatchLog {
  id           String          @id @default(cuid())
  claimId      String
  blastId      String          @default(cuid())
  contractorId String
  notifiedAt   DateTime        @default(now())
  acceptedAt   DateTime?
  outcome      DispatchOutcome @default(PENDING)
  createdAt    DateTime        @default(now())
  claim      Claim             @relation(fields: [claimId], references: [id], onDelete: Cascade)
  contractor ContractorProfile @relation(fields: [contractorId], references: [id])
}

model PendingContractor {
  id               String             @id @default(cuid())
  name             String
  companyName      String
  email            String
  phone            String?
  tradeType        ContractorTradeType
  coverageAreaText String?
  tosSignature     String?
  tosStatus        TosStatus          @default(SENT)
  submittedByPolicyholderId String?
  reviewedByAdminId         String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  submittedBy PolicyholderProfile? @relation("SubmittedByPolicyholder", fields: [submittedByPolicyholderId], references: [id])
  reviewedBy  User?                @relation("ReviewedByAdmin", fields: [reviewedByAdminId], references: [id])
}
